{
  "redirects": [
    {
      "source": "/category-:cat.html",
      "destination": "/:cat",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms-of-service.html",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/affiliate-disclosure.html",
      "destination": "/disclosure",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/serums",
      "destination": "/fragrance",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms-of-service.html"
    },
    {
      "source": "/disclosure",
      "destination": "/affiliate-disclosure.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/p/:cat/:id",
      "destination": "/product.html"
    },
    {
      "source": "/:cat(skincare|facemasks|makeup|haircare|fragrance)",
      "destination": "/category.html"
    }
  ],
  "trailingSlash": false
}